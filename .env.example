# ── Receipts configuration ──────────────────────────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# Environment: "development" (default) or "production".
# In production a missing/short RECEIPT_SECRET is a hard startup failure.
ENVIRONMENT=production

# HMAC signing key. REQUIRED in production, >=16 chars. Generate e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
RECEIPT_SECRET=

# Storage. Only sqlite:/// is supported today; the URL form leaves room for Postgres later.
DATABASE_URL=sqlite:///./receipts.db

# Comma-separated allowed CORS origins (the dashboard's origin). No "*" in production.
CORS_ORIGINS=http://localhost:5173

# API keys that may call the backend. Comma-separated "label:role:rawkey" entries.
# Roles: viewer (read-only dashboard), proxy (record receipts + verify), admin (all).
# Seeded into the api_keys table on first startup. Generate keys with token_urlsafe.
API_KEYS=dashboard:viewer:CHANGE_ME_VIEWER,proxy:proxy:CHANGE_ME_PROXY

# Disable the built-in mock demo tools (/tools/call) in production.
ENABLE_DEMO_TOOLS=false

# Ops
LOG_LEVEL=INFO
LOG_JSON=true
RATE_LIMIT=120/minute

# ── MCP proxy (receipts_mcp) ────────────────────────────────────────────────
RECEIPTS_URL=http://localhost:8000
# The proxy-role key from API_KEYS above (the raw value).
RECEIPTS_API_KEY=CHANGE_ME_PROXY
UPSTREAMS_PATH=receipts_mcp/upstreams.json

# ── Frontend (build-time) ───────────────────────────────────────────────────
# Backend base URL the SPA talks to. Behind the bundled nginx this stays relative.
VITE_BACKEND_URL=
# Dev only: key the SPA sends directly (use the proxy key — dashboard needs writes).
VITE_RECEIPTS_VIEWER_KEY=CHANGE_ME_PROXY

# ── Docker / nginx ───────────────────────────────────────────────────────────
# Proxy-role key injected by nginx into every backend request (never ships in the
# JS bundle). The dashboard does reads AND writes, so it needs the proxy key.
RECEIPTS_PROXY_KEY=CHANGE_ME_PROXY
